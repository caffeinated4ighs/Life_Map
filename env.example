# Life System — Environment Variables Template
# Copy this file to .env and fill in all values.
# Never commit .env to version control.

# ── Required ───────────────────────────────────────────────────────────────

# Supabase project URL (from Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (from Settings → API → service_role)
# WARNING: This key bypasses Row Level Security. Keep it secret.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Groq API key (from console.groq.com → API Keys)
GROQ_API_KEY=gsk_your-groq-api-key-here

# Groq model identifier (e.g. llama3-8b-8192, mixtral-8x7b-32768)
GROQ_MODEL_ID=llama3-8b-8192

# Your local timezone (IANA format, e.g. America/New_York, Europe/London)
TIMEZONE=America/New_York

# ── Optional ───────────────────────────────────────────────────────────────

# Logging verbosity: DEBUG | INFO | WARN | ERROR (default: INFO)
LOG_LEVEL=INFO

# Path to the Supabase health-check Edge Function endpoint
# Produced by the DB Agent. Default shown below.
HEALTH_CHECK_PATH=/functions/v1/health
